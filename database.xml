<?xml version="1.0" encoding="UTF-8"?>
<database>

    <global>
        <table name="currency">
            <field type="string" length="5" primary="true">currency</field>
            <field type="float" default="1">rate</field>
            <field type="boolean" default="0">autoupdate</field>
            <field type="smallint" default="2">precision</field>
            <field type="string" length="255" default="default">type</field>
            <field type="text" nullable="true" default="null">customData</field>
        </table>
    </global>

</database>
